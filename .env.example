# HAProxy Configuration
HAPROXY_LOG_LEVEL=info
HAPROXY_MAXCONN=4096

# Backend Servers (comma-separated)
# Format: server_name:host:port
BACKEND_SERVERS=server1:backend1:8001,server2:backend2:8002,server3:backend3:8003

# Load Balancing Algorithm
# Options: roundrobin, leastconn, static-rr, source, uri, url_param, hdr
LOAD_BALANCE_MODE=roundrobin

# Port Configuration
HAPROXY_FRONTEND_PORT=80
HAPROXY_STATS_PORT=8404

# SSL/TLS (optional)
# ENABLE_SSL=false
# SSL_CERT_PATH=/etc/ssl/certs/haproxy.pem

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=5000
HEALTH_CHECK_TIMEOUT=4000

# Timeouts (in milliseconds)
TIMEOUT_CONNECT=5000
TIMEOUT_CLIENT=50000
TIMEOUT_SERVER=50000

# Stats Dashboard
STATS_ENABLED=true
STATS_URI=/stats
STATS_REFRESH=30

# Environment
ENVIRONMENT=development
TZ=UTC
